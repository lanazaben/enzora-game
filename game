
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  /* ===== THEME ===== */
  :root {
    --gradient-main: linear-gradient(135deg, #4facfe, #8e44ad);
    --gradient-soft: linear-gradient(135deg, #eef4ff, #f5e9ff);

    --color-primary: #6c5ce7;
    --color-primary-dark: #4b3cc4;

    --color-bg: #f7f9fc;
    --color-card: #ffffff;

    --color-text-primary: #1f2937;
    --color-text-secondary: #6b7280;

    --color-border: #e5e7eb;
  }

  body {
    direction: rtl;
    min-height: 100vh;

    /* center EVERYTHING */
    display: flex;
    justify-content: center;
    align-items: center;

    background: var(--gradient-soft);
  }

  #app {
    font-family: 'Segoe UI', Tahoma, sans-serif;
    direction: rtl;

    width: 100%;
    max-width: 680px;

    padding: 1.5rem;
  }

  .screen { display: none; }
  .screen.active { display: block; }

  /* ===== WELCOME ===== */
  .welcome-header { text-align: center; padding: 2rem 0 1rem; }

  .logo-badge {
    display: inline-block;
    background: white;
    border-radius: 999px;
    padding: 0.4rem 1.3rem;
    font-size: 13px;
    color: var(--color-primary);
    margin-bottom: 1rem;
    border: 1px solid var(--color-border);
  }

  .welcome-title {
    font-size: 28px;
    font-weight: 600;
    background: var(--gradient-main);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.5rem;
  }

  .welcome-sub {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .name-section {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }

  .name-label {
    font-size: 13px;
    color: var(--color-text-secondary);
    margin-bottom: 8px;
  }

  .name-input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    font-size: 15px;
    background: #fafafa;
  }

  .name-input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  /* ===== PRIMARY BUTTON ===== */
  .start-btn,
  .play-again-btn {
    width: 100%;
    padding: 14px;
    background: var(--gradient-main);
    color: white;
    border: none;
    border-radius: 14px;
    font-size: 16px;
    cursor: pointer;
    transition: 0.2s;
  }

  .start-btn:hover,
  .play-again-btn:hover {
    opacity: 0.9;
  }

  /* ===== PROGRESS ===== */
  .progress-bar-wrap {
    background: #eaeef5;
    border-radius: 99px;
    height: 6px;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: var(--gradient-main);
    border-radius: 99px;
    transition: width 0.4s;
  }

  .q-counter {
    font-size: 13px;
    color: var(--color-text-secondary);
    text-align: center;
    margin-bottom: 0.5rem;
  }

  /* ===== CARD ===== */
  .q-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .q-text {
    font-size: 17px;
    color: var(--color-text-primary);
    line-height: 1.7;
  }

  /* ===== ANSWERS ===== */
  .answer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 1rem;
  }

  .ans-btn {
    padding: 14px;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: white;
    cursor: pointer;
    transition: 0.2s;
  }

  .ans-btn:hover:not(:disabled) {
    border-color: var(--color-primary);
    background: #f4f2ff;
  }

  .ans-btn.correct {
    background: #e8f0ff;
    border-color: #4facfe;
    color: #2c3e94;
  }

  .ans-btn.wrong {
    background: #fde8ef;
    border-color: #e05678;
    color: #a82d4f;
  }

  /* ===== TIMER ===== */
  .timer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .timer-num {
    font-size: 20px;
    font-weight: 600;
    color: var(--color-primary);
  }

  .timer-num.urgent {
    color: #e05678;
  }

  /* ===== RESULTS ===== */
  .result-score-big {
    font-size: 56px;
    font-weight: 700;
    background: var(--gradient-main);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .enzora-promo {
    background: var(--gradient-soft);
    border-radius: 14px;
    padding: 1rem;
    margin-top: 1rem;
    text-align: center;
  }
</style>

<div id="app" dir="rtl">

  <div id="welcome-screen" class="screen active">
    <div class="welcome-header">
      <div class="logo-badge">Enzora — Smart Wound Patch</div>
      <h1 class="welcome-title">حقيقة أم خرافة؟</h1>
      <p class="welcome-sub">اختبر معلوماتك عن مرض السكري والجروح — 15 سؤال، 15 ثانية لكل سؤال. هل تعرف الفرق بين الحقيقة والشائعة؟</p>
    </div>
    <div class="name-section">
      <div class="name-label">أدخل اسمك للمنافسة على لوحة المتصدرين</div>
      <input class="name-input" type="text" id="player-name" placeholder="اسمك هنا..." />
    </div>
    <button class="start-btn" onclick="startGame()">ابدأ التحدي</button>
  </div>

  <div id="quiz-screen" class="screen">
    <div class="timer-row">
      <span class="score-pill">النقاط: <span id="score-display">0</span></span>
      <span class="timer-num" id="timer-display">15</span>
    </div>
    <div class="progress-bar-wrap"><div class="progress-bar-fill" id="progress-fill" style="width:0%"></div></div>
    <div class="q-counter" id="q-counter">السؤال 1 من 15</div>
    <div class="q-card">
      <span class="q-tag" id="q-tag"></span>
      <p class="q-text" id="q-text"></p>
    </div>
    <div class="answer-grid">
      <button class="ans-btn" id="btn-true" onclick="answer(true)">حقيقة</button>
      <button class="ans-btn" id="btn-false" onclick="answer(false)">خرافة</button>
    </div>
    <div id="feedback-area"></div>
    <button class="next-btn" id="next-btn" style="display:none" onclick="nextQuestion()">السؤال التالي ←</button>
  </div>

  <div id="result-screen" class="screen">
    <div class="result-header">
      <div class="result-score-big" id="final-score"></div>
      <div class="result-label">نقطة من أصل 15</div>
      <div class="result-name" id="final-name"></div>
    </div>
    <div class="enzora-promo">
      <div class="enzora-promo-title">تعرّف على Enzora</div>
      <div class="enzora-promo-sub">ضمادة ذكية تكشف عدوى الجروح قبل تطور المضاعفات — خصوصاً لمرضى السكري</div>
    </div>
    <div class="leaderboard-title">لوحة المتصدرين</div>
    <div id="leaderboard"></div>
    <button class="play-again-btn" onclick="resetGame()">العب مجدداً</button>
  </div>

</div>

<script>
