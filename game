let currentQ = 0;
let score = 0;
let playerName = '';
let timerInterval = null;
let timeLeft = 15;
let answered = false;
let leaderboard = [];

function startGame() {
  playerName = document.getElementById('player-name').value.trim() || 'مجهول';
  currentQ = 0; score = 0; answered = false;
  showScreen('quiz-screen');
  renderQuestion();
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function renderQuestion() {
  if (currentQ >= questions.length) { endGame(); return; }
  answered = false;
  const q = questions[currentQ];
  document.getElementById('q-counter').textContent = 'السؤال ' + (currentQ + 1) + ' من ' + questions.length;
  document.getElementById('progress-fill').style.width = ((currentQ / questions.length) * 100) + '%';
  document.getElementById('q-text').textContent = q.text;
  document.getElementById('q-tag').textContent = q.answer ? 'حقيقة أم خرافة؟' : 'حقيقة أم خرافة؟';
  document.getElementById('q-tag').className = 'q-tag tag-fact';
  document.getElementById('score-display').textContent = score;
  document.getElementById('feedback-area').innerHTML = '';
  document.getElementById('next-btn').style.display = 'none';
  const btnTrue = document.getElementById('btn-true');
  const btnFalse = document.getElementById('btn-false');
  btnTrue.className = 'ans-btn'; btnTrue.disabled = false;
  btnFalse.className = 'ans-btn'; btnFalse.disabled = false;
  startTimer();
}

function startTimer() {
  clearInterval(timerInterval);
  timeLeft = 15;
  updateTimerDisplay();
  timerInterval = setInterval(() => {
    timeLeft--;
    updateTimerDisplay();
    if (timeLeft <= 0) { clearInterval(timerInterval); if (!answered) { timeOut(); } }
  }, 1000);
}

function updateTimerDisplay() {
  const el = document.getElementById('timer-display');
  el.textContent = timeLeft;
  el.className = timeLeft <= 5 ? 'timer-num urgent' : 'timer-num';
}

function timeOut() {
  answered = true;
  const q = questions[currentQ];
  document.getElementById('btn-true').disabled = true;
  document.getElementById('btn-false').disabled = true;
  document.getElementById('btn-' + (q.answer ? 'true' : 'false')).classList.add('correct');
  showFeedback(false, q);
}

function answer(userAnswer) {
  if (answered) return;
  answered = true;
  clearInterval(timerInterval);
  const q = questions[currentQ];
  const correct = userAnswer === q.answer;
  if (correct) { score += timeLeft > 10 ? 3 : timeLeft > 5 ? 2 : 1; }
  document.getElementById('btn-true').disabled = true;
  document.getElementById('btn-false').disabled = true;
  document.getElementById('btn-' + (userAnswer ? 'true' : 'false')).classList.add(correct ? 'correct' : 'wrong');
  if (!correct) document.getElementById('btn-' + (q.answer ? 'true' : 'false')).classList.add('correct');
  document.getElementById('score-display').textContent = score;
  showFeedback(correct, q);
}

function showFeedback(correct, q) {
  let html = '<div class="feedback-box ' + (correct ? 'feedback-correct' : 'feedback-wrong') + '">';
  html += '<strong>' + (correct ? 'إجابة صحيحة!' : 'إجابة خاطئة') + '</strong><br>' + q.feedback;
  html += '</div>';
  if (q.enzoraLink) {
    html += '<div class="enzora-note"><span class="enzora-icon">Enzora</span> — ' + q.enzoraLink + '</div>';
  }
  document.getElementById('feedback-area').innerHTML = html;
  document.getElementById('next-btn').style.display = 'block';
}

function nextQuestion() {
  currentQ++;
  renderQuestion();
}

function endGame() {
  leaderboard.push({ name: playerName, score: score });
  leaderboard.sort((a, b) => b.score - a.score);
  document.getElementById('final-score').textContent = score;
  document.getElementById('final-name').textContent = playerName;
  const lb = document.getElementById('leaderboard');
  lb.innerHTML = leaderboard.slice(0, 10).map((entry, i) => {
    const isCurrent = entry.name === playerName && entry.score === score;
    const medal = i === 0 ? '1' : i === 1 ? '2' : i === 2 ? '3' : (i + 1) + '';
    return '<div class="lb-row">' +
      '<span class="lb-rank ' + (i === 0 ? 'gold' : '') + '">' + medal + '</span>' +
      '<span class="lb-name ' + (isCurrent ? 'current' : '') + '">' + entry.name + (isCurrent ? ' ←أنت' : '') + '</span>' +
      '<span class="lb-score">' + entry.score + '</span></div>';
  }).join('');
  showScreen('result-screen');
}

function resetGame() {
  document.getElementById('player-name').value = '';
  showScreen('welcome-screen');
}
</script>
